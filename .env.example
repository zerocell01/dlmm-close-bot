# ── Wallet ────────────────────────────────────────────────────────────────
# Base58 private key. Same wallet you used to open positions manually.
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── RPC ───────────────────────────────────────────────────────────────────
# Used for SENDING transactions (claim fee, remove liquidity, close).
# Paid RPC recommended here for reliability (Helius/QuickNode etc).
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Used for POLLING position state every few seconds. Free/public RPC is fine
# for this — it's read-only and low volume. Defaults to a public endpoint
# if left blank.
POLL_RPC_URL=https://pump.helius-rpc.com

# ── Safety ────────────────────────────────────────────────────────────────
# ALWAYS test with DRY_RUN=true first. No transactions are sent — the bot
# only logs what it WOULD do.
DRY_RUN=true

# ── Telegram notifications (optional) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
